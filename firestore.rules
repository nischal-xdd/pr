rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "jhonelmira@gmail.com";
    }

    match /contacts/{document=**} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /pageReactions/home {
      allow read: if true;
      allow create, update: if request.auth != null;
    }

    match /pageReactions/home/votes/{voteId} {
      allow read: if request.auth != null && request.auth.uid == voteId;
      allow create, update: if request.auth != null && request.auth.uid == voteId;
      allow delete: if isAdmin();
    }

    match /pageReactions/home/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }
  }
}
